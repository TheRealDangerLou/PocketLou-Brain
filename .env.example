# Pocket Lou Brain — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Required: Claude (primary LLM) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── God-tier upgrade: Multi-model routing ────────────────────────────────────
# Optional — enables GPT-4o-mini for fast conversational replies
OPENAI_API_KEY=your_openai_key_here

# Optional — enables live internet search via Perplexity
PERPLEXITY_API_KEY=your_perplexity_key_here

# ── Memory ────────────────────────────────────────────────────────────────────
# Optional — override default ChromaDB path
# CHROMA_DB_PATH=./brain/memory/chroma_db

# ── Optional overrides ───────────────────────────────────────────────────────
# POCKET_LOU_MODE=STANDARD
# POCKET_LOU_CONFIG=config/settings.json
# POCKET_LOU_LOG_LEVEL=WARNING

# ── Phase 2: Voice (future) ──────────────────────────────────────────────────
# WHISPER_MODEL=base
# PIPER_VOICE=en_US-lessac-medium
